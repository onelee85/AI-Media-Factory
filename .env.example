# App
APP_NAME=AI-Media-Factory
DEBUG=false

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_media_factory
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_media_factory

# Storage
STORAGE_ROOT=./storage

# FFmpeg
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe

# Celery Queues
CELERY_QUEUES=tts,media,render,compose

# LLM API
OPEN_API_BASE=https://openrouter.ai/api/v1
OPEN_API_KEY=your-api-key
